{
    "openapi": "3.0.0",
    "info": {
        "title": "API Empresas",
        "description": "Documentación oficial de la API de Empresas",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Entorno Actual"
        }
    ],
    "paths": {
        "/api/v1/companies": {
            "get": {
                "tags": [
                    "1. Plan Free / General"
                ],
                "summary": "Obtener Empresa por CIF",
                "description": "Devuelve los datos detallados de una empresa a partir de su CIF exacto. **Coste:** 1 llamada de tu cuota mensual (plan suscripción) o 1 crédito del monedero (bono prepago). Las respuestas con error (400, 404, etc.) no consumen cuota ni créditos.",
                "operationId": "3306da725bbecc96cbd63f46540e56ae",
                "parameters": [
                    {
                        "name": "cif",
                        "in": "query",
                        "description": "El CIF de la empresa a consultar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "admin",
                        "in": "query",
                        "description": "Si es 'true', incluye los administradores y cargos directivos actuales de la empresa. Exclusivo para planes Pro y Business.",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Datos de la empresa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Error de validación o formato de CIF incorrecto",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "error": {
                                            "description": "Código del error: 'VALIDATION_ERROR' o 'INVALID_CIF_FORMAT'",
                                            "type": "string",
                                            "example": "INVALID_CIF_FORMAT"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "El CIF proporcionado no tiene un formato válido (debe tener una letra, 7 dígitos y un dígito o letra de control)."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Empresa no encontrada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "error": {
                                            "type": "string",
                                            "example": "COMPANY_NOT_FOUND"
                                        },
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/companies/search": {
            "get": {
                "tags": [
                    "1. Plan Free / General"
                ],
                "summary": "Búsqueda de Empresas",
                "description": "Busca empresas por nombre o CIF. Permite búsqueda exacta o paginada. **Coste:** 1 llamada de tu cuota mensual (plan suscripción) o 1 crédito del monedero (bono prepago). Las respuestas con error (400, 404, etc.) no consumen cuota ni créditos.",
                "operationId": "7505c6f7c5eb0d2af39a3177326b5617",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Nombre o CIF de la empresa a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "multiple",
                        "in": "query",
                        "description": "Si es true, devuelve una lista paginada de coincidencias. Si es false, devuelve la mejor coincidencia.",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Número máximo de resultados por página (solo si multiple=true). Máximo 100.",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Número de página (solo si multiple=true).",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Resultados de la búsqueda",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
