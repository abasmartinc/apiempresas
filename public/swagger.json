                        "description": "Filtro por provincia",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "range",
                        "in": "query",
                        "description": "Rango de tiempo: 'hoy', '7' días o '30' días",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "hoy"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Leads encontrados",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "meta": {
                                            "type": "object"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
